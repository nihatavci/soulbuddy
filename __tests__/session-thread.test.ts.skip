import { groupMessagesIntoTurns } from '../app/(app)/session';

// ─── Mock Message type ────────────────────────────────────────────────────────

type MockMessage = {
  id: string;
  session_id: string;
  role: 'user' | 'assistant';
  content: string;
  metadata: Record<string, unknown>;
  created_at: string;
};

function makeMsg(
  id: string,
  role: 'user' | 'assistant',
  content = '',
  metadata: Record<string, unknown> = {},
): MockMessage {
  return {
    id,
    session_id: 'session-1',
    role,
    content,
    metadata,
    created_at: new Date().toISOString(),
  };
}

// ─── groupMessagesIntoTurns ───────────────────────────────────────────────────

describe('groupMessagesIntoTurns', () => {
  it('returns [] for empty array', () => {
    expect(groupMessagesIntoTurns([])).toEqual([]);
  });

  it('returns 1 turn for 1 user + 1 assistant message', () => {
    const messages = [
      makeMsg('u1', 'user', 'hey'),
      makeMsg('a1', 'assistant', 'hi there'),
    ];
    const turns = groupMessagesIntoTurns(messages as any);
    expect(turns).toHaveLength(1);
    expect(turns[0].userMessage.id).toBe('u1');
    expect(turns[0].assistantMessages).toHaveLength(1);
    expect(turns[0].assistantMessages[0].id).toBe('a1');
  });

  it('returns 2 turns for 2 user messages each followed by assistant', () => {
    const messages = [
      makeMsg('u1', 'user', 'first'),
      makeMsg('a1', 'assistant', 'reply 1'),
      makeMsg('u2', 'user', 'second'),
      makeMsg('a2', 'assistant', 'reply 2'),
    ];
    const turns = groupMessagesIntoTurns(messages as any);
    expect(turns).toHaveLength(2);
    expect(turns[0].userMessage.id).toBe('u1');
    expect(turns[1].userMessage.id).toBe('u2');
  });

  it('ignores assistant messages without a preceding user message', () => {
    const messages = [
      makeMsg('a0', 'assistant', 'orphan'),
      makeMsg('u1', 'user', 'first user'),
      makeMsg('a1', 'assistant', 'reply'),
    ];
    const turns = groupMessagesIntoTurns(messages as any);
    // orphan assistant message is ignored — only 1 valid turn
    expect(turns).toHaveLength(1);
    expect(turns[0].userMessage.id).toBe('u1');
  });

  it('supports multiple assistant messages per turn', () => {
    const messages = [
      makeMsg('u1', 'user', 'first'),
      makeMsg('a1', 'assistant', 'tone 1'),
      makeMsg('a2', 'assistant', 'tone 2'),
      makeMsg('a3', 'assistant', 'tone 3'),
    ];
    const turns = groupMessagesIntoTurns(messages as any);
    expect(turns).toHaveLength(1);
    expect(turns[0].assistantMessages).toHaveLength(3);
  });
});

