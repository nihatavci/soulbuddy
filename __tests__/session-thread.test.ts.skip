jest.mock('expo-clipboard', () => ({ setStringAsync: jest.fn() }));
// Reanimated's Easing.bezier is not provided by jest-expo's preset mock —
// stub it with an identity function so transitive imports of animation
// configs don't crash at module load.
jest.mock('react-native-reanimated', () => {
  const mock = jest.requireActual('react-native-reanimated/mock');
  const bezier = () => (t: number) => t;
  // The default jest mock omits Easing; conf.ts at module-load time calls
  // Easing.bezier(...) and crashes without this stub.
  mock.Easing = { bezier, linear: (t: number) => t, ease: (t: number) => t, in: bezier, out: bezier, inOut: bezier };
  mock.default = mock.default ?? mock;
  return mock;
});
