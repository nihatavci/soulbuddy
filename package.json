    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-glass-effect": "~0.1.10",
    "expo-haptics": "~15.0.8",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-store-review": "~9.0.9",
    "expo-tracking-transparency": "~6.0.8",
    "expo-updates": "~29.0.16",
    "expo-video": "~3.0.16",
    "i18next": "^26.0.1",
    "mixpanel-react-native": "^3.3.0",
    "nativewind": "4.1.23",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-error-boundary": "^6.1.1",
    "react-i18next": "^17.0.1",
    "react-native": "0.81.5",
    "react-native-appsflyer": "^6.17.9",
    "react-native-fbsdk-next": "^13.4.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-mmkv": "^3.3.3",
    "react-native-onesignal": "^5.3.1",
    "react-native-purchases": "^9.14.0",
    "react-native-purchases-ui": "^9.14.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-view-shot": "4.0.3",
    "react-native-worklets": "^0.5.1",
    "tailwindcss": "^3.4.1"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "ajv": "^8.18.0",
    "eslint": "^10.0.2",
    "eslint-config-expo": "~10.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "expo-mcp": "~0.2.1",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "onesignal-expo-plugin": "^2.0.4",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "react-test-renderer": "^19.1.0",
    "teenybase": "^0.0.14",
    "typescript": "^5.9.3"
  },
  "expo": {
    "autolinking": {
      "android": {
        "exclude": [
          "@solana-mobile/mobile-wallet-adapter-protocol",
          "@solana-mobile/mobile-wallet-adapter-protocol-web3js",
          "@solana-mobile/wallet-adapter-mobile",
          "@solana-mobile/wallet-standard-mobile",
          "@solana/wallet-adapter-base",
          "@solana/wallet-adapter-react"
        ]
      },
      "ios": {
        "exclude": [
          "@solana-mobile/mobile-wallet-adapter-protocol",
          "@solana-mobile/mobile-wallet-adapter-protocol-web3js",
          "@solana-mobile/wallet-adapter-mobile",
          "@solana-mobile/wallet-standard-mobile",
          "@solana/wallet-adapter-base",
          "@solana/wallet-adapter-react"
        ]
      }
    },
    "install": {
      "exclude": [
        "jest-expo"
      ]
    }
  },
  "jest": {
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^@ungap/structured-clone$": "<rootDir>/__mocks__/structuredCloneMock.js",
      "^expo/src/winter(.*)$": "<rootDir>/__mocks__/expoWinterEmpty.js",
      "^react-native-mmkv$": "<rootDir>/__mocks__/react-native-mmkv.js",
      "^mixpanel-react-native$": "<rootDir>/__mocks__/mixpanel-react-native.js"
    },
    "preset": "jest-expo",
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/.claude/worktrees/"
    ],
    "modulePathIgnorePatterns": [
      "/.claude/worktrees/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|react-native-purchases|react-native-purchases-ui|react-native-onesignal|mixpanel-react-native|@sentry/.*)"
    ]
  },
  "main": "expo-router/entry",
  "name": "myapp",
  "scripts": {
    "android": "expo run:android",
    "build:backend": "teeny build --local",
    "deploy:backend:remote": "teeny deploy --migrate --remote",
    "dev:backend": "teeny dev --local",
    "exec:backend": "teeny exec --local",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "generate:backend": "teeny generate --local",
    "ios": "expo run:ios",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "migrate:backend": "teeny migrate --local",
    "postinstall": "npx patch-package",
    "start": "EXPO_NO_DEPENDENCY_VALIDATION=1 expo start --tunnel",
    "start:ios": "bash sim-start.sh",
    "start:lan": "expo start",
    "start:simulator": "bash sim-start.sh",
    "test": "jest --watchAll=false",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "web": "expo start --web"
  },
  "version": "1.0.0"
}
